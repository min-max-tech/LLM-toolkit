# Copy to .env and set BASE_PATH. Everything else has sensible defaults.
# Do not commit .env.

# --- Required ---
# Project root (use forward slashes on Windows). e.g. . or C:/dev/AI-toolkit
BASE_PATH=.
# Optional: separate data directory (default: BASE_PATH/data)
# DATA_PATH=D:/ai-data

# --- Models ---
# Ollama models to pull on first start (comma-separated).
MODELS=qwen3:8b,deepseek-r1:7b,deepseek-coder:6.7b,nomic-embed-text
# Default model used across the dashboard (Open WebUI, Model Gateway, etc.)
DEFAULT_MODEL=jaahas/qwen3.5-uncensored:27b

# --- OpenClaw ---
# Auto-generated by ensure_dirs script. Only set manually if re-pairing devices.
# OPENCLAW_GATEWAY_TOKEN=
# Discord bot token — set here; compose maps it to DISCORD_BOT_TOKEN in openclaw-gateway.
# openclaw-config-sync rewrites channels.discord.token to env SecretRef when this is set (no plaintext in JSON).
# DISCORD_TOKEN=
# Telegram (optional) — OpenClaw reads TELEGRAM_BOT_TOKEN; merge script uses SecretRef when set.
# TELEGRAM_BOT_TOKEN=

# --- Compute ---
# Auto-detected by scripts/detect_hardware.py. Override: nvidia, amd, intel, cpu
# COMPUTE_MODE=nvidia
# COMPOSE_FILE=docker-compose.yml;overrides/compute.yml
# Expose Ollama (11434) and MCP gateway (8811) on localhost for Cursor/doctor (see overrides/ollama-expose.yml, overrides/mcp-expose.yml):
# COMPOSE_FILE=docker-compose.yml;overrides/compute.yml;overrides/ollama-expose.yml;overrides/mcp-expose.yml

# --- Optional ---
# N8N webhook URL (for OAuth callbacks; requires Tailscale Funnel)
# N8N_WEBHOOK_URL=https://your-machine.your-tailnet.ts.net
# N8N MCP server — API key for full workflow access (Settings → API in n8n UI)
# N8N_API_KEY=
# N8N_API_URL=http://n8n:5678
# Dashboard API auth (optional): Bearer token on /api/* when set
# DASHBOARD_AUTH_TOKEN=
# Ops controller token (required for model downloads, service restart). Generate: openssl rand -hex 32
# OPS_CONTROLLER_TOKEN=
# HuggingFace token (for gated model downloads)
# HF_TOKEN=
# GitHub personal access token (for GitHub MCP tool — repo read/write, issues, PRs, etc.)
# GITHUB_PERSONAL_ACCESS_TOKEN=
# Native OpenClaw web_search (Brave). Optional — prefer gateway__call + duckduckgo__search (MCP) for no-key search.
# BRAVE_API_KEY=
# MCP servers (comma-separated). Default: n8n,playwright,comfyui
# MCP_GATEWAY_SERVERS=n8n,playwright,comfyui
# Claude Code local model (convenience var for wrapper scripts)
# CLAUDE_CODE_LOCAL_MODEL=qwen3:8b

# --- RAG (--profile rag: Qdrant + rag-ingestion) ---
# Embedding model must exist in Ollama (pull via dashboard or model-puller). Default matches MODELS list.
# EMBED_MODEL=nomic-embed-text
# Qdrant host port when published (compose default maps 6333)
# QDRANT_PORT=6333
# Vector collection name (must match Open WebUI / ingestion)
# RAG_COLLECTION=documents
# Chunking for rag-ingestion (tokens ≈ words for plain text)
# RAG_CHUNK_SIZE=400
# RAG_CHUNK_OVERLAP=50
