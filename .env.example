# Copy to .env and set BASE_PATH. Everything else has sensible defaults.
# Do not commit .env.

# --- Required ---
# Project root (use forward slashes on Windows). e.g. . or C:/dev/ordo-ai-stack
BASE_PATH=.
# Optional: separate data directory (default: BASE_PATH/data)
# DATA_PATH=D:/ai-data

# --- Models (llama.cpp / GGUF) ---
# Main chat model filename under models/gguf/ (must exist before llamacpp starts).
# LLAMACPP_MODEL=qwen3.5-35b-q4_k_m.gguf
# Embedding model filename under models/gguf/ (llamacpp-embed).
# LLAMACPP_EMBED_MODEL=nomic-embed-text-v1.5.Q8_0.gguf
# Context size passed to llama-server --ctx-size.
# This is the real hard cap seen by Open WebUI, Cline, Claude Code, and any other clients routed through model-gateway.
# Default repo behavior is 256k so agent/dev-tool clients have a long-context baseline without extra setup.
# LLAMACPP_CTX_SIZE=262144
# Optional: advertise a smaller OpenClaw context window than the server hard cap for earlier compaction.
# Leave unset to match LLAMACPP_CTX_SIZE exactly.
# OPENCLAW_CONTEXT_WINDOW=262144
# OpenClaw session compaction policy for long chats. "safeguard" is the better default for large
# local models because it trims/offloads history before prompt prefill becomes the bottleneck.
# OPENCLAW_COMPACTION_MODE=safeguard
# Agent-level wall clock timeout for long tool loops / downloads.
# OPENCLAW_AGENT_TIMEOUT_SECONDS=3600
# LLM idle timeout before OpenClaw assumes the provider is stuck. Keep this high for large local
# models where first-token latency grows with prompt size.
# OPENCLAW_LLM_IDLE_TIMEOUT_SECONDS=900
# Per-file bootstrap prompt cap for OpenClaw workspace files injected into the system prompt.
# Lower than upstream defaults to keep `/new` and first-turn prompts compact.
# OPENCLAW_BOOTSTRAP_MAX_CHARS=3000
# Total bootstrap prompt cap across injected workspace files.
# OPENCLAW_BOOTSTRAP_TOTAL_MAX_CHARS=8000
# MCP bridge HTTP connect timeout to mcp-gateway.
# OPENCLAW_MCP_CONNECT_TIMEOUT_MS=10000
# MCP bridge per-request timeout. Long-running MCP tools like media generation must exceed 30000 ms.
# OPENCLAW_MCP_REQUEST_TIMEOUT_MS=900000
# Hard input-token budget for OpenClaw requests routed through model-gateway. Prevents slow decode by
# trimming prompts before they reach llama.cpp, regardless of the model's full context window.
# Uses character-based estimation (~1.5x undercount vs actual tokens), so 16384 ≈ 24-26k real tokens.
# Set 0 to disable trimming entirely.
# Optional: explicit Open WebUI default.
# OPEN_WEBUI_DEFAULT_MODEL=
# GPU layers (-1 = all).
# LLAMACPP_GPU_LAYERS=-1
# Flash Attention mode forwarded to llama-server (`auto`, `on`, `off`).
# LLAMACPP_FLASH_ATTN=auto
# Feature flag: when set to 1, llama.cpp starts with quantized KV cache flags.
# LLAMACPP_ENABLE_KV_CACHE_QUANTIZATION=0
# KV cache types used when quantization is enabled. Valid values depend on the llama.cpp build
# but current supported examples include q8_0, q4_0, q4_1, iq4_nl, q5_0, and q5_1.
# LLAMACPP_KV_CACHE_TYPE_K=q4_0
# LLAMACPP_KV_CACHE_TYPE_V=q4_0
# Optional raw llama-server args appended last. Useful for one-off experiments without editing compose.
# LLAMACPP_EXTRA_ARGS=
# Pull GGUFs once: docker compose --profile models run --rm gguf-puller
# GGUF_MODELS=org/repo-with-gguf-files
# Default model id shown in Open WebUI (must match a model id from GET /v1/models, often the GGUF basename).
DEFAULT_MODEL=model.gguf

# --- OpenClaw ---
# Gateway / CLI image — official GHCR (default pinned in docker-compose.yml). Release: https://github.com/openclaw/openclaw/releases
# Package: https://github.com/openclaw/openclaw/pkgs/container/openclaw — use :latest to track HEAD or pin a version tag.
# Note: the pinned GHCR image may report `Unsupported channel: discord`; use a source-built image
# (`OPENCLAW_IMAGE=openclaw:local`) if you need Primus reachable from Discord on this stack.
# OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:2026.4.1
# Auto-generated by ensure_dirs script. Only set manually if re-pairing devices.
# OPENCLAW_GATEWAY_TOKEN=
# Must match the port the gateway process listens on *inside* the container (default 6680). If you use overrides/openclaw-secure.yml, set this to match that file (e.g. 18789) and align openclaw-gateway command/healthcheck via the override.
# OPENCLAW_GATEWAY_INTERNAL_PORT=6680
# Discord bot token — openclaw-config-sync rewrites channels.discord.token to a SecretRef when set:
#   {"source":"env","provider":"default","id":"DISCORD_BOT_TOKEN"} (provider required on OpenClaw 2026.3.x).
# DISCORD_TOKEN=
# Comma-separated guild (server) snowflake IDs — required for OpenClaw to accept messages & slash
# commands in server channels when groupPolicy is allowlist (default).
# From a channel URL: discord.com/channels/<GUILD_ID>/<CHANNEL_ID>
# OPENCLAW_DISCORD_GUILD_IDS=1234567890123456789
# Optional comma-separated Discord user snowflake IDs — merged into every guild's users allowlist.
# Requires OPENCLAW_DISCORD_GUILD_IDS to be set (or guilds already present in openclaw.json);
# without guild entries the user IDs are not applied and a warning is printed during config-sync.
# OPENCLAW_DISCORD_USER_IDS=123456789012345678
# Telegram (optional) — OpenClaw reads TELEGRAM_BOT_TOKEN; merge script uses SecretRef when set.
# TELEGRAM_BOT_TOKEN=
# Set to 1 to keep a minimal custom TOOLS.md in data/openclaw/workspace (skip auto-upgrade from TOOLS.md.example).
# OPENCLAW_SKIP_TOOLS_MD_UPGRADE=0
# In Docker, Control UI "Update" usually stalls (binary is image-baked). merge_gateway_config disables in-app update checks unless:
# OPENCLAW_ALLOW_IN_APP_UPDATE=1

# --- Compute ---
# Auto-detected by scripts/detect_hardware.py. Override: nvidia, amd, intel, cpu
# COMPUTE_MODE=nvidia
# COMPOSE_FILE=docker-compose.yml;overrides/compute.yml
#
# ComfyUI CLI (passed as CLI_ARGS). GPU stacks: include --normalvram so text encoders stay on GPU
# (omit --lowvram unless you need OOM fallback). Set explicitly or let detect_hardware.py append it.
# COMFYUI_CLI_ARGS=--disable-xformers --normalvram --enable-manager
# LTX Gemma: if encode fails with cudaErrorInvalidValue at sd1_clip.py torch.cat(...).to(intermediate_device), try:
#   PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
# or add --gpu-only to COMFYUI_CLI_ARGS (keeps intermediates on GPU; uses more VRAM).
# Override ComfyUI container RAM limit (mirrored into Compose `mem_limit` and the generated `deploy.resources` block).
# LTX+VideoVAE load spikes need headroom.
# COMFYUI_MEMORY_LIMIT=64G
# Expose MCP gateway (8811) on localhost for Cursor/doctor (see overrides/mcp-expose.yml):
# COMPOSE_FILE=docker-compose.yml;overrides/compute.yml;overrides/mcp-expose.yml

# --- Optional ---
# N8N webhook URL (for OAuth callbacks; requires Tailscale Funnel)
# N8N_WEBHOOK_URL=https://your-machine.your-tailnet.ts.net
# Orchestration publish_enqueue default target — n8n should own retries, OAuth, rate limits (not OpenClaw).
# N8N_PUBLISH_WEBHOOK_URL=https://your-machine.your-tailnet.ts.net/webhook/...
# Gate readiness on ComfyUI + workflow dir (default 0; set 1 for image-gen stacks)
# ORCHESTRATION_MEDIA_REQUIRED=0
# comfyui-mcp: allow implicit workflow_id from COMFY_MCP_DEFAULT_WORKFLOW_ID when flat prompt/width (compose default 0 = explicit workflow_id; default id mcp-api/generate_image)
# COMFY_MCP_ALLOW_DEFAULT_WORKFLOW_ID=0
# Default checkpoint model for ComfyUI MCP generate_image / queue_prompt.
# Must match a filename in data/comfyui-storage/ComfyUI/models/checkpoints/.
# COMFY_MCP_DEFAULT_MODEL=flux1-schnell-fp8.safetensors
# N8N MCP server — API key for full workflow access (Settings → API in n8n UI)
# N8N_API_KEY=
# N8N_API_URL=http://n8n:5678
# Dashboard API auth (optional): Bearer token on /api/* when set
# DASHBOARD_AUTH_TOKEN=
# Ops controller token (required for model downloads, service restart, ComfyUI custom-node pip via dashboard). Generate: openssl rand -hex 32
# OPS_CONTROLLER_TOKEN=
# HuggingFace token (for gated model downloads)
# HF_TOKEN=
# GitHub personal access token (for GitHub MCP tool — repo read/write, issues, PRs, etc.)
# Also passed to the comfyui container as GITHUB_TOKEN for ComfyUI-Manager (custom node installs, API rate limits).
# GITHUB_PERSONAL_ACCESS_TOKEN=
# Native OpenClaw web_search is disabled in openclaw.json (tools.web.search.enabled: false).
# Web search uses MCP: gateway__tavily_search / gateway__search. Do not set BRAVE_API_KEY unless you re-enable native search.
# Set to 1 to stop merge_gateway_config from forcing tools.web.search.enabled: false (then configure OpenClaw web tools).
# OPENCLAW_NATIVE_WEB_SEARCH=0
# Built-in OpenClaw `browser` tool is denied by default (no bundled browser). Web: Tavily MCP + web_fetch; see mcp/README.md.
# Set to 1 only if you install a browser in the gateway or run a native OpenClaw and need the built-in browser tool.
# OPENCLAW_ALLOW_BUILTIN_BROWSER=0
# Allow OpenClaw exec "elevated" (e.g. sudo) from webchat/Control UI — off by default; see TROUBLESHOOTING (OpenClaw → browser/elevated).
# OPENCLAW_ELEVATED_ALLOW_WEBCHAT=1
# Trust model: full exec on the gateway container (tools.exec host=gateway security=full ask=off) + elevated for webchat+discord.
# Set to 1 so OpenClaw has maximum practical control of the stack via tools (then: docker compose run --rm openclaw-config-sync; restart openclaw-gateway).
# For apt/installs you usually also need root: compose -f docker-compose.yml -f overrides/openclaw-gateway-root.yml …
# OPENCLAW_UNRESTRICTED_GATEWAY_CONTAINER=1
# BRAVE_API_KEY=
# Tavily API — required for MCP server `tavily` (search, extract, crawl, map, research). https://app.tavily.com
# No trailing spaces after the key. After changing: docker compose restart mcp-gateway (and openclaw-gateway if tools were cached).
# TAVILY_API_KEY=
# OpenClaude Docker CLI profile (`docker compose --profile openclaude-cli run --rm openclaude-cli`).
# Host setup scripts also configure local `openclaude` installs to use the same gateway automatically.
# Set OPENCLAUDE_MODEL if you want a specific model preselected; otherwise DEFAULT_MODEL is used when available.
# OPENCLAUDE_NPM_VERSION=latest
# OPENCLAUDE_MODEL=model.gguf
# OPENCLAUDE_OPENAI_API_KEY=local
# MCP servers for mcp-gateway (comma-separated). Default: duckduckgo + n8n + tavily + comfyui (registry-custom.yaml catalog fragment adds ComfyUI via --additional-catalog).
# MCP_GATEWAY_SERVERS=duckduckgo,n8n,tavily,comfyui
# Verbose docker/mcp-gateway logs (debug missing ComfyUI tools). See docs/runbooks/TROUBLESHOOTING.md
# MCP_GATEWAY_VERBOSE=1
# LiteLLM proxy master key. Set this in .env to use the LiteLLM Admin UI and authenticate in-stack gateway clients.
# LITELLM_MASTER_KEY=local
# Claude-compatible local model alias used by LiteLLM/model-gateway when a client still sends `claude-*` ids.
# CLAUDE_CODE_LOCAL_MODEL=qwen3:8b

# --- RAG (--profile rag: Qdrant + rag-ingestion) ---
# Embedding model used by rag-ingestion and Open WebUI document embeddings via model-gateway.
# Default matches the dedicated llama.cpp embed server model.
# EMBED_MODEL=nomic-embed-text-v1.5.Q4_K_M.gguf
# Qdrant host port when published (compose default maps 6333)
# QDRANT_PORT=6333
# If compose fails with "Bind for 0.0.0.0:6333 failed: port is already allocated", set another host port (containers still use 6333 internally).
# Vector collection name (must match Open WebUI / ingestion)
# RAG_COLLECTION=documents
# Chunking for rag-ingestion (tokens ≈ words for plain text)
# RAG_CHUNK_SIZE=400
# RAG_CHUNK_OVERLAP=50
# RAG_SCAN_INTERVAL_SEC=15

# --- Worker throughput ---
# Queue poll interval (seconds). Lower = faster job pickup, higher CPU. Default 0.5s.
# WORKER_POLL_INTERVAL_SEC=0.5
# WORKER_CONCURRENCY=2
# WORKER_WAL_CHECKPOINT_SEC=300
# WORKER_VACUUM_SEC=86400

# --- MCP gateway reload behavior ---
# MCP_GATEWAY_POLL_SEC=5
# MCP_GATEWAY_RELOAD_DEBOUNCE_SEC=20
