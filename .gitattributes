# Ensure shell scripts use LF so they run in Linux containers.
# Broader *.sh rule prevents CRLF regressions when new scripts are added
# (e.g. on Windows checkouts with autocrlf=true).
*.sh text eol=lf
dashboard/entrypoint.sh text eol=lf
hermes/entrypoint.sh text eol=lf
scripts/llamacpp/run-llama-server.sh text eol=lf

# SOPS-encrypted files store metadata that includes a timestamp followed
# by `\n`; SOPS rejects the file outright on Windows checkouts where
# autocrlf=true rewrites that newline as `\r\n`.
*.sops text eol=lf
secrets/.sops.yaml text eol=lf
