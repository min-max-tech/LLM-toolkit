#!/usr/bin/env bash
# ordo-ai-stack — project management CLI
# Usage: ./ordo-ai-stack [command]
#
# Commands:
#   launch       Ensure directories/workspace, then start the stack without forcing rebuilds
#   initialize   Bootstrap directories, config, hardware profile, then rebuild/recreate and start the full default stack
#   help         Show this help

set -euo pipefail

BOLD='\033[1m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
BLUE='\033[0;34m'; RED='\033[0;31m'; DIM='\033[2m'; NC='\033[0m'

ok()      { printf "  ${GREEN}✓${NC}  %s\n" "$*"; }
info()    { printf "  ${BLUE}·${NC}  %s\n" "$*"; }
warn()    { printf "  ${YELLOW}!${NC}  %s\n" "$*"; }
err()     { printf "  ${RED}✗${NC}  %s\n" "$*" >&2; }
section() { printf "\n${BOLD}── %s ${DIM}%s${NC}\n" "$1" "$2"; }

repo_root() {
  if [[ -n "${BASE_PATH:-}" ]]; then
    echo "${BASE_PATH//\\//}"
    return
  fi
  local here
  here="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  echo "${here//\\//}"
}

# ── initialize ─────────────────────────────────────────────────────────────────

cmd_launch() {
  local base data
  base="$(repo_root)"
  data="${DATA_PATH:-$base/data}"

  if [[ ! -f "$base/docker-compose.yml" ]]; then
    err "No docker-compose.yml under: $base"
    err "Set BASE_PATH to your Ordo AI Stack repo root, or run this script from the repo (./ordo-ai-stack launch)."
    exit 1
  fi

  printf "\n${YELLOW}"
  cat <<'BANNER'
  ___          _       
 / _ \ _ __ __| | ___  
| | | | '__/ _` |/ _ \ 
| |_| | | | (_| | (_) |
 \___/|_|  \__,_|\___/
BANNER
  printf "${NC}"
  printf "${DIM}  base=%s  data=%s${NC}\n" "$base" "$data"

  export BASE_PATH="$base"

  section "1/3" "Directories and hardware profile"
  bash "$base/scripts/ensure_dirs.sh"

  section "2/3" "OpenClaw workspace templates"
  if [[ -f "$base/openclaw/scripts/ensure_openclaw_workspace.sh" ]]; then
    bash "$base/openclaw/scripts/ensure_openclaw_workspace.sh"
  else
    warn "openclaw/scripts/ensure_openclaw_workspace.sh not found — skipped"
  fi

  section "3/3" "Docker — start Ordo stack"
  info "docker compose up -d"
  ( cd "$base" && docker compose up -d )

  printf "\n${BOLD}${GREEN}✓  Ordo is up${NC}\n\n"
  printf "  ${BOLD}%-22s${NC} %s\n" "Dashboard"      "http://localhost:8080"
  printf "  ${BOLD}%-22s${NC} %s\n" "OpenClaw"       "http://localhost:6680"
  printf "  ${BOLD}%-22s${NC} %s\n" "Open WebUI"     "http://localhost:3000"
  printf "\n"
}

cmd_initialize() {
  local base data
  base="$(repo_root)"
  data="${DATA_PATH:-$base/data}"

  if [[ ! -f "$base/docker-compose.yml" ]]; then
    err "No docker-compose.yml under: $base"
    err "Set BASE_PATH to your Ordo AI Stack repo root, or run this script from the repo (./ordo-ai-stack initialize)."
    exit 1
  fi

  printf "\n${YELLOW}"
  # shellcheck disable=SC2016 # figlet "standard" wordmark; quotes/backticks must stay literal
  cat <<'BANNER'
  ___          _       
 / _ \ _ __ __| | ___  
| | | | '__/ _` |/ _ \ 
| |_| | | | (_| | (_) |
 \___/|_|  \__,_|\___/
BANNER
  printf "${NC}"
  printf "${DIM}  base=%s  data=%s${NC}\n" "$base" "$data"

  export BASE_PATH="$base"

  section "1/3" "Directories, config, hardware (ensure_dirs)"
  if [[ ! -f "$base/scripts/ensure_dirs.sh" ]]; then
    err "Missing scripts/ensure_dirs.sh"
    exit 1
  fi
  bash "$base/scripts/ensure_dirs.sh"

  section "2/3" "OpenClaw workspace templates (if missing)"
  if [[ -f "$base/openclaw/scripts/ensure_openclaw_workspace.sh" ]]; then
    bash "$base/openclaw/scripts/ensure_openclaw_workspace.sh"
  else
    warn "openclaw/scripts/ensure_openclaw_workspace.sh not found — skipped"
  fi

  section "3/3" "Docker — build, recreate, start full stack"
  info "docker compose up -d --build --force-recreate"
  ( cd "$base" && docker compose up -d --build --force-recreate )

  printf "\n${BOLD}${GREEN}✓  Ready${NC}\n\n"
  printf "  ${BOLD}%-22s${NC} %s\n" "Dashboard"      "http://localhost:8080"
  printf "  ${BOLD}%-22s${NC} %s\n" "Open WebUI"     "http://localhost:3000"
  printf "  ${BOLD}%-22s${NC} %s\n" "ComfyUI"        "http://localhost:8188"
  printf "  ${BOLD}%-22s${NC} %s\n" "N8N"            "http://localhost:5678"
  printf "  ${BOLD}%-22s${NC} %s\n" "OpenClaw"       "http://localhost:6680"
  printf "  ${BOLD}%-22s${NC} %s\n" "Model Gateway"  "http://localhost:11435"
  printf "\n${DIM}Pull Ollama models:   docker compose run --rm model-puller${NC}\n"
  printf "${DIM}Pull ComfyUI models:  docker compose --profile comfyui-models run --rm comfyui-model-puller${NC}\n\n"
}

# ── dispatch ───────────────────────────────────────────────────────────────────
cmd="${1:-launch}"
case "$cmd" in
  launch|start|up) cmd_launch ;;
  initialize|init) cmd_initialize ;;
  help|--help|-h)
    sed -n 's/^# \{0,1\}//p' "$0" | sed -n '2,/^$/p'
    ;;
  *)
    err "Unknown command: $cmd"
    printf "Run ${BOLD}./ordo-ai-stack help${NC} for usage.\n"
    exit 1
    ;;
esac
