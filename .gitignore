.env
.env.compute
mcp/.env
overrides/compute.yml
models/
data/

# Secrets / keys (never commit)
*.pem
*.key
*.kubeconfig

# Debug / temporary
comfyui-logs.txt
comfyui*.log
.pytest_cache
pytest-cache-files-*
tmp*
__pycache__
*.pyc

# Local dev (personal notes, full troubleshooting)
context/
.claude/scheduled_tasks.lock
.claude/settings.local.json
cp_test_output.log
test_output.log

# Untracked sibling projects that happen to live in this tree
/isolated_portfolio/

# Hermes Agent (host-mode install + local state; see docs/hermes-agent.md)
vendor/hermes-agent/
data/hermes/

# Tailscale-issued TLS material for Caddy front door — per-host, NEVER commit
auth/caddy/certs/

# Secrets — only encrypted .sops files plus README/.sops.yaml are tracked.
# Any plaintext file someone drops in secrets/ is rejected by default,
# so a slipped `secrets/temp.env` or `secrets/notes.txt` cannot leak.
secrets/*
!secrets/*.sops
!secrets/.sops.yaml
!secrets/README.md
!secrets/.gitkeep
