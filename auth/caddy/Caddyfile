{
    # Listen only on the tailnet interface; the bind address is
    # controlled at compose level via CADDY_BIND.
    auto_https off
}

{$CADDY_TAILNET_HOSTNAME} {
    # Tailscale-issued cert (mounted in by host).
    tls /etc/caddy/certs/tailnet.crt /etc/caddy/certs/tailnet.key

    # ---- forward_auth (oauth2-proxy) on every protected path ----
    # TODO(plan-a-task-10): oauth2-proxy emits X-Auth-Request-Email /
    # X-Auth-Request-User / X-Auth-Request-Preferred-Username on /oauth2/auth.
    # Either pass --set-xauthrequest=true to oauth2-proxy and rename here,
    # or align dashboard `_verify_auth()` to read X-Auth-Request-Email
    # instead of X-Forwarded-Email. The header copy below is the current
    # plan's wording; resolve the mismatch when wiring the first real
    # upstream (Task 10).
    @auth not path /oauth2/* /healthz
    handle @auth {
        forward_auth oauth2-proxy:4180 {
            uri /oauth2/auth
            copy_headers X-Forwarded-Email X-Forwarded-User X-Forwarded-Preferred-Username
        }
    }

    # ---- oauth2-proxy endpoints (start, callback, sign_out) ----
    handle /oauth2/* {
        reverse_proxy oauth2-proxy:4180
    }

    # ---- public health (no auth) ----
    handle /healthz {
        respond "ok" 200
    }

    # ---- Upstream UIs are wired in subsequent tasks (Plan A Tasks 10-14). ----
    handle {
        respond "auth ok — no route configured for this path yet" 404
    }
}
