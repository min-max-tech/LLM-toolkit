{
    # Listen only on the tailnet interface; the bind address is
    # controlled at compose level via CADDY_BIND.
    auto_https off
}

# Plain-HTTP healthz on :80 for the in-container Docker healthcheck
# (caddy:2-alpine's wget targets http://localhost/healthz). The 443
# host block below also serves /healthz publicly for tailnet probes.
:80 {
    handle /healthz {
        respond "ok" 200
    }
    handle {
        respond "use https" 421
    }
}

{$CADDY_TAILNET_HOSTNAME} {
    # Tailscale-issued cert (mounted in by host).
    tls /etc/caddy/certs/tailnet.crt /etc/caddy/certs/tailnet.key

    # ---- forward_auth (oauth2-proxy) on every protected path ----
    @auth not path /oauth2/* /healthz /n8n/rest/oauth2-credential/callback /n8n/webhook/*
    handle @auth {
        forward_auth oauth2-proxy:4180 {
            uri /oauth2/auth
            copy_headers X-Auth-Request-Email>X-Forwarded-Email X-Auth-Request-User>X-Forwarded-User X-Auth-Request-Preferred-Username>X-Forwarded-Preferred-Username
            # Convert oauth2-proxy's 401 (no session) into a 302 redirect to
            # /oauth2/start, preserving the original URL via rd= so the user
            # is bounced back after Google sign-in.
            @unauthorized status 401
            handle_response @unauthorized {
                redir https://{host}/oauth2/start?rd={scheme}://{host}{uri} 302
            }
        }
    }

    # ---- oauth2-proxy endpoints (start, callback, sign_out) ----
    handle /oauth2/* {
        reverse_proxy oauth2-proxy:4180
    }

    # ---- public health (no auth) ----
    handle /healthz {
        respond "ok" 200
    }

    # ---- /dash/ → dashboard:8080 ----
    handle_path /dash/* {
        reverse_proxy dashboard:8080
    }

    # ---- /chat/ → open-webui ----
    handle_path /chat/* {
        reverse_proxy open-webui:8080
    }

    # ---- /n8n/ → n8n (OAuth callback + webhooks bypass SSO via @auth exclusion above) ----
    handle_path /n8n/* {
        reverse_proxy n8n:5678
    }

    # ---- /hermes/ → hermes-dashboard ----
    handle_path /hermes/* {
        reverse_proxy hermes-dashboard:9119
    }

    # ---- /comfy/ → comfyui (WebSocket auto-upgrade via reverse_proxy) ----
    handle_path /comfy/* {
        reverse_proxy comfyui:8188
    }

    # ---- catch-all 404 for paths that don't match any route above ----
    handle {
        respond "auth ok — unknown route" 404
    }
}
