{
  "mcpServers": {
    "gateway": {
      "transport": "http",
      "url": "http://{{ host }}:{{ mcp_gateway_port }}/mcp"
    }{% if include_blog %},
    "blog": {
      "transport": "http",
      "url": "http://{{ host }}:{{ blog_port }}/mcp",
      "headers": { "x-api-key": "{{ blog_api_key }}" }
    }{% endif %},
    "local-tools": {
      "transport": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "{{ local_workspace_path }}"
      ]
    }
  }
}
